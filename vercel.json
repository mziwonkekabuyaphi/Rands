{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/super-admin",
      "destination": "/super-admin.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/staff",
      "destination": "/staff.html"
    },
    {
      "source": "/home",
      "destination": "/home.html"
    },
    {
      "source": "/register",
      "destination": "/register.html"
    },
    {
      "source": "/even-manager",
      "destination": "/even-manager.html"
    },
    {
      "source": "/box-office",
      "destination": "/box-office.html"
    },
    {
      "source": "/ticket-store",
      "destination": "/ticket-store.html"
    },
    {
      "source": "/(.*)",
      "destination": "/404.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}